# 阿里云一键同步（复制为 scripts/aliyun.env，勿提交 git）
# cp scripts/aliyun.env.example scripts/aliyun.env

# SSH 登录（与 nuanban_github/config/demo.env 二选一，本文件优先）
ALIYUN_SSH=root@101.200.128.82

# 服务器 monorepo 根目录
ALIYUN_REPO_DIR=/opt/jinshouzhi

# 暖伴部署目录（相对或绝对均可）
NUANBAN_REMOTE_DIR=/opt/jinshouzhi/nuanban_github

# 古蜀秘档静态目录（git pull 后即为仓库内 match3-game）
MATCH3_REMOTE_DIR=/opt/jinshouzhi/match3-game

# 公网访问（备案后用域名，备案中用 IP）
# ALIYUN_DOMAIN=nuanban.cc
# ALIYUN_STAGING_IP=101.200.128.82

# 古蜀秘档 URL 路径（Caddy 反代，勿改除非改 Caddyfile）
MATCH3_URL_PATH=/game
