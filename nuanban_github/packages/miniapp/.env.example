# H5 开发用代理时填 /api；直连 PocketBase 时填 http://localhost:8090/api
VITE_API_BASE_URL=/api

# 开发账号（先执行 ../../scripts/seed-demo.sh）
VITE_DEV_AUTH_EMAIL=student1@test.nuanban.dev

# npm run dev:h5 默认已启用虚拟手机登录；生产构建需显式开启：
# VITE_VIRTUAL_PHONE_LOGIN=true

# 发布渠道（构建脚本注入，勿手动改）：
