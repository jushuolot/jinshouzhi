# H5 开发用代理时填 /api；直连 PocketBase 时填 http://localhost:8090/api
VITE_API_BASE_URL=/api

# 开发账号（先执行 ../../scripts/seed-demo.sh）
VITE_DEV_AUTH_EMAIL=student1@test.nuanban.dev

# —— 本地正式产品测试（默认 · 比发布版更新，走真实登录流）——
# PocketBase 测试数据：./scripts/dev-test.sh → ./scripts/start-h5.sh
# VITE_DEMO_MOCK 必须为 false；浏览器 Mock 仅 GitHub Pages（Actions 注入 true）
# formal = 角标「正式版」：无 000000 捷径、无游客入口，验证码见运营发件箱
VITE_RELEASE_CHANNEL=formal
VITE_DEMO_MOCK=false

# —— 构建脚本注入（勿手动改生产构建）——
# VITE_RELEASE_CHANNEL=release  # GitHub Pages 发布版（Actions 注入）
# VITE_RELEASE_CHANNEL=stable   # 阿里云发布稳定版
