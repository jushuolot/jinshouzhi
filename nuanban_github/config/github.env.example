# GitHub 公网演示配置（复制为 config/github.env，勿提交）
# cp config/github.env.example config/github.env

# 客人打开的固定链接（GitHub Pages，push 后自动更新）
NUANBAN_PAGES_URL=https://jushuolot.github.io/jinshouzhi/nuanban/
NUANBAN_DEMO_URL=https://jushuolot.github.io/jinshouzhi/nuanban/#/pages/common/login

# Render 免费 API（Blueprint 部署 nuanban-demo 后填写，无自购域名）
NUANBAN_API_URL=https://nuanban-demo.onrender.com

# GitHub 仓库名（决定 Pages 子路径，一般无需改）
GITHUB_REPO=jinshouzhi
