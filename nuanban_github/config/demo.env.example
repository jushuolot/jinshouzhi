# 阿里云正式版配置（复制为 config/demo.env，勿提交 git）
# cp config/demo.env.example config/demo.env
#
# 发布规则：GitHub Pages=测试版 ./scripts/release-test.sh
#          阿里云=正式版 ./scripts/release-prod.sh

# 正式域名（备案通过后 + DNS A 记录，Caddy 自动 HTTPS）
NUANBAN_DOMAIN=nuanban.cc
NUANBAN_DEMO_URL=https://nuanban.cc/#/pages/common/login

# 备案期间临时用公网 IP 测试（deploy-staging.sh，HTTP 无证书）
NUANBAN_STAGING_IP=101.200.128.82
# sync-check.sh 公网 API 检测（默认可由 STAGING_IP 推导）
# NUANBAN_PUBLIC_API=http://101.200.128.82

# 本机同步到公网时 SSH（sync-public.sh 使用）
NUANBAN_SSH=root@your-server-ip
NUANBAN_REMOTE_DIR=/opt/jinshouzhi/nuanban_github

# 古蜀秘档（与 scripts/aliyun-sync-all.sh 同步）
# MATCH3_REMOTE_DIR=/opt/jinshouzhi/match3-game
# MATCH3_URL_PATH=/game

# 演示数据 seed 密钥（与 seed-demo.sh 默认一致，一般无需改）
# NUANBAN_SEED_KEY=nuanban_dev_seed
