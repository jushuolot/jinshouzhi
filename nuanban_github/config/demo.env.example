# 公网演示站配置（复制为 config/demo.env，勿提交 git）
# cp config/demo.env.example config/demo.env

# 演示域名（已解析到云服务器，Caddy 自动 HTTPS）
NUANBAN_DOMAIN=demo.yourdomain.com

# 发给客人的固定链接（可含 hash 路由）
NUANBAN_DEMO_URL=https://demo.yourdomain.com/#/pages/common/login

# 本机同步到公网时 SSH（sync-public.sh 使用）
NUANBAN_SSH=root@your-server-ip
NUANBAN_REMOTE_DIR=/opt/nuanban_github

# 演示数据 seed 密钥（与 seed-demo.sh 默认一致，一般无需改）
# NUANBAN_SEED_KEY=nuanban_dev_seed
