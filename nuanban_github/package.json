{
  "name": "nuanban",
  "version": "0.2.0",
  "private": true,
  "description": "暖伴勤工 - uni-app + PocketBase 精简栈",
  "workspaces": [
    "packages/miniapp"
  ],
  "scripts": {
    "miniapp:dev": "npm run dev:h5 -w packages/miniapp",
