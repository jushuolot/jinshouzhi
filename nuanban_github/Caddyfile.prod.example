# 公网演示站 Caddy 配置（由 deploy-public.sh 根据域名生成 Caddyfile.prod）
# 将 __DOMAIN__ 替换为你的演示域名，DNS A 记录指向云服务器

__DOMAIN__ {
	handle /api/* {
		reverse_proxy pocketbase:8090
	}

	handle /_/* {
		reverse_proxy pocketbase:8090
	}

	# 古蜀秘档 · 三星堆消消（monorepo match3-game 静态站）
	handle /game/* {
		uri strip_prefix /game
		root * /srv/match3-game
		try_files {path} /index.html
		file_server
	}

	handle /game {
		redir /game/ permanent
	}

	handle {
		root * /srv/h5
		try_files {path} /index.html
		file_server
	}
}
