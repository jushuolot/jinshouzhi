# 公网 V2 Caddy 配置（由 deploy-v2.sh / deploy-public.sh 生成 Caddyfile.prod）
# 占位符：__DOMAIN__ __USER_HOST__ __CONTROL_HOST__

# 根域 → 用户端
__DOMAIN__, www.__DOMAIN__ {
	redir https://__USER_HOST__{uri} permanent
}

# 用户端 H5 + API
__USER_HOST__ {
	handle /api/* {
		reverse_proxy pocketbase:8090
	}

	handle /_/* {
		reverse_proxy pocketbase:8090
	}

	handle /login {
		redir /#/pages/common/login permanent
	}
	handle /login/* {
		redir /#/pages/common/login permanent
	}

	handle {
		root * /srv/h5-user
		try_files {path} /index.html
		file_server
	}
}

# 运营台 H5 + API
__CONTROL_HOST__ {
	handle /api/* {
		reverse_proxy pocketbase:8090
	}

	handle /_/* {
		reverse_proxy pocketbase:8090
	}

	handle {
		root * /srv/h5-control
		try_files {path} /index.html
		file_server
	}
}
