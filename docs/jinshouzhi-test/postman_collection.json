{
  "info": {
    "name": "金手指-测试验收",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "导入 Postman 后设置变量 baseUrl, maleToken, femaleToken, adminToken"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api-test.example.com/v1" },
    { "key": "maleToken", "value": "" },
    { "key": "femaleToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "conversationId", "value": "" }
  ],
  "item": [
    {
      "name": "邀请",
      "item": [
        {
          "name": "JSZ-API-01 校验邀请码成功",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"invite_code\": \"INV_M001\"\n}" },
            "url": "{{baseUrl}}/invite/validate"
          }
        }
      ]
    },
    {
      "name": "男士保证金",
      "item": [
        {
          "name": "JSZ-API-06 保证金账户",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{maleToken}}" }],
            "url": "{{baseUrl}}/deposit/account"
          }
        },
        {
          "name": "JSZ-API-10 发起分配",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{maleToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/assignment/request"
          }
        },
        {
          "name": "JSZ-API-09 分配配额",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{maleToken}}" }],
            "url": "{{baseUrl}}/assignment/quota"
          }
        }
      ]
    },
    {
      "name": "女士",
      "item": [
        {
          "name": "JSZ-API-08 暂停接收",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{femaleToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"enabled\": false\n}" },
            "url": "{{baseUrl}}/female/settings/receiving"
          }
        }
      ]
    },
    {
      "name": "隐私",
      "item": [
        {
          "name": "JSZ-API-12 会话对方脱敏",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{maleToken}}" }],
            "url": "{{baseUrl}}/conversation/{{conversationId}}/peer"
          }
        },
        {
          "name": "JSZ-API-14 女士列表应失败",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{maleToken}}" }],
            "url": "{{baseUrl}}/users/female/list"
          }
        }
      ]
    }
  ]
}
