# 复制为 secrets.toml 并修改（该文件勿提交 Git）

# 登录密码（单用户必填）
STOCK_ASSISTANT_PASSWORD = "请改成强密码"

# 多用户（可选）：不同密码 → 不同 data/users/<id>/ 数据
# [passwords]
# alice = "密码A"
# bob = "密码B"

# 公网 App 地址（可选；填后在侧边栏生成「分享给同事」文案）
# STOCK_APP_PUBLIC_URL = "https://your-app.streamlit.app"
# 可选：GitHub Actions 用 API 自动重启（不配置也会 git push 自动部署）
# STREAMLIT_API_TOKEN = "..."
# STREAMLIT_APP_ID = "..."
# 可选：覆盖云端扫盘 JSON 地址（默认 raw.githubusercontent.com/.../latest_picks.json）
# STOCK_CLOUD_STATE_URL = "https://raw.githubusercontent.com/..."

# Webhook 推送速览（可选，见 docs/PUSH.md）
# STOCK_WEBHOOK_URL = "https://your-webhook-url"

# 数据源故障告警 Webhook（可选，与速览 Webhook 可不同）
# STOCK_HEALTH_ALERT_WEBHOOK_URL = "https://your-alert-webhook"

# SMTP 邮件推送（可选）
# [smtp]
# host = "smtp.example.com"
# port = 587
# user = "your@email.com"
# password = "app-password"
# to = "colleague@example.com"
# from = "Stock Assistant <your@email.com>"
